# Copy this file to .env and replace the password for local development.
POSTGRES_DB=lotto_analysis
POSTGRES_USER=lotto_app
POSTGRES_PASSWORD=replace-with-a-local-development-password
POSTGRES_PORT=5432
POSTGRES_HOST=127.0.0.1
# Comma-separated browser origins allowed to call FastAPI.
LOTTO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
